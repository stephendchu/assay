# Model-backed mapper/graders — pick ONE backend, then run a *_llm_demo.py.
# Copy to .env (gitignored) and fill in.  Offline tests need none of this.

# Claude — the portfolio default:
ANTHROPIC_API_KEY=

# OR a free OpenAI-compatible backend (Groq / OpenRouter / local Ollama):
# ASSAY_LLM_PROVIDER=openai
# ASSAY_LLM_BASE_URL=https://api.groq.com/openai/v1
# ASSAY_LLM_API_KEY=
# ASSAY_LLM_MODEL=llama-3.3-70b-versatile

# Optional: override the judge/mapper model (anthropic backend):
# ASSAY_LLM_MODEL=claude-sonnet-4-6
